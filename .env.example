# Copy to .env — never commit secrets

# Database — must match a real Postgres role and database on your machine.
# Docker Compose creates user scoutpro / db baseball_project; local installs often use postgres / postgres.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://scoutpro:scoutpro@localhost:5433/baseball_project

# Redis (caching / GDS opponent profiles)
REDIS_URL=redis://localhost:6379/0

# Dev: bypass JWT and use a fixed dev user (never enable in production)
SCOUTPRO_DEV_AUTH=1

# Clerk (https://clerk.com) — frontend + JWT verification
SCOUTPRO_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
SCOUTPRO_CLERK_SECRET_KEY=sk_test_placeholder
SCOUTPRO_CLERK_ISSUER=

# Stripe — billing
SCOUTPRO_STRIPE_SECRET_KEY=sk_test_placeholder
SCOUTPRO_STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
STRIPE_SUCCESS_URL=http://localhost:5173/dashboard
STRIPE_CANCEL_URL=http://localhost:5173/pricing

# Observability (optional)
SENTRY_DSN=

# Optional: CSV with columns mlb_id, has_mlb_games for label cross-check (see ml/lahman_optional.py)
# LAHMAN_MLB_FLAGS_CSV=
